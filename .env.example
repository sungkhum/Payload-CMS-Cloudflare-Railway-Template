# ============================================================
# Payload + Next.js
# ============================================================
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace_me_with_long_random_string

# Port the Next.js server binds to. Honored by `next dev`, `next start`, and
# the Docker standalone server. Railway injects its own PORT at runtime.
PORT=3125

# Public origin of the deployed site (used for CSRF, cookies, sitemap)
# Local dev: http://localhost:3125  |  Prod: https://your-domain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3125

# Site name used in titles, OG tags, etc. (override "Boxcar" with your brand)
NEXT_PUBLIC_SITE_NAME=Boxcar

# ============================================================
# Database (PostgreSQL on Railway)
# ============================================================
# Local dev (via docker-compose): postgresql://payload:payload@localhost:5432/payload
# On Railway: provided automatically as ${{ Postgres.DATABASE_URL }} reference
DATABASE_URI=postgresql://payload:payload@localhost:5432/payload

# ============================================================
# Cloudflare R2 (S3-compatible media storage) — OPTIONAL
# ============================================================
# Leave R2_BUCKET / R2_ENDPOINT blank to skip R2 entirely; the Media collection
# falls back to Payload's built-in local-filesystem storage (fine for dev, but
# ephemeral on Railway — set R2 vars before relying on uploads in production).

# Bucket name (e.g. boxcar-media)
R2_BUCKET=boxcar-media

# S3 endpoint: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# R2 API token credentials (NOT your Cloudflare account API key)
# Create in Cloudflare dash → R2 → Manage API Tokens → "Object Read & Write"
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Public URL where uploaded media is served from.
# Either an R2 public bucket URL (https://pub-xxx.r2.dev) or a custom domain
# you've connected in the R2 settings (https://media.your-domain.com).
R2_PUBLIC_URL=https://pub-xxx.r2.dev
